{
  "_version": "1.83.0",
  "sap.app": {
    "id": "sap.com.bedigix.approvectrfe",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.21.0",
      "toolsId": "0a57e16d-618c-414c-b528-b76ac9467a8f"
    },
    "crossNavigation": {
      "inbounds": {
        "contractsRelease-Display": {
          "semanticObject": "contractsRelease",
          "action": "Display",
          "title": "{{contractsRelease-Display.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "sap-icon://detail-view",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    },
    "fullWidth": true
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "sap.com.bedigix.approvectrfe.i18n.i18n"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "sap.com.bedigix.approvectrfe.view",
        "controlAggregation": "detailPages",
        "controlId": "idAppControl",
        "clearTarget": false,
        "clearControlAggregation": false,
        "bypassed": {
          "target": [
            "PurchaseOrderDetails",
            "purchase_orders"
          ]
        }
      },
      "routes": [
        {
          "name": "purchase_orders",
          "pattern": "purchase_orders",
          "target": [
            "PurchaseOrderDetails",
            "purchase_orders"
          ]
        },
        {
          "pattern": "purchase_orders/PurchaseOrderDetails/:context:",
          "name": "PurchaseOrderDetails",
          "target": [
            "purchase_orders",
            "PurchaseOrderDetails"
          ]
        },
        {
          "pattern": "purchase_orders/line_item/:context:",
          "name": "line_item",
          "target": [
            "purchase_orders",
            "line_item"
          ]
        },
        {
          "pattern": "",
          "name": "default",
          "target": [
            "PurchaseOrderDetails",
            "purchase_orders"
          ]
        }
      ],
      "targets": {
        "purchase_orders": {
          "controlAggregation": "masterPages",
          "viewName": "purchase_orders",
          "viewId": "purchase_orders",
          "viewLevel": 1,
          "transition": "slide"
        },
        "PurchaseOrderDetails": {
          "controlAggregation": "detailPages",
          "viewName": "PurchaseOrderDetails",
          "viewId": "PurchaseOrderDetails",
          "viewLevel": 2,
          "transition": "slide"
        },
        "line_item": {
          "controlAggregation": "detailPages",
          "viewName": "line_item",
          "viewId": "line_item",
          "viewLevel": 1,
          "transition": "slide"
        }
      }
    },
    "rootView": {
      "viewName": "sap.com.bedigix.approvectrfe.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    },
    "autoPrefixId": true
  },
  "sap.cloud": {
    "public": true,
    "service": "sapcombedigixapprovectrfe"
  }
}